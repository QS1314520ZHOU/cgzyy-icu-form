# MongoDB 连接配置
# DataCenter 库：包含 VI_ICU_ZYYZ 等医嘱视图/集合
MONGO_DATACENTER_URI=mongodb://data:Data%40dmin@10.35.4.12:32121/DataCenter

# SmartCare 库：包含 patient、bedside 等集合
MONGO_SMARTCARE_URI=mongodb://dxm:DB%40dmin@10.35.4.12:32121/SmartCare

# 服务端口
PORT=3000

# 运行环境
NODE_ENV=production

# MongoDB 连接超时时间，单位毫秒
MONGO_TIMEOUT_MS=10000

# 是否按科室字段过滤；默认 false 更安全，避免源数据无科室字段时统计为 0
ENABLE_DEPT_FILTER=false

# 时区
TZ=Asia/Shanghai

