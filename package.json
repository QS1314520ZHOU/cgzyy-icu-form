{
  "name": "icu-stats",
  "version": "1.0.0",
  "description": "ICU重症医学科辅助功能系统",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:oel8": "pkg . --targets node18-linux-x64 --output dist/icu-stats-oel8-x64"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.16.1",
    "nodemon": "^3.0.1"
  },
  "bin": "server.js",
  "pkg": {
    "scripts": [
      "config/**/*.js",
      "models/**/*.js",
      "routes/**/*.js",
      "services/**/*.js"
    ],
    "assets": [
      "public/**/*",
      "node_modules/xlsx/dist/xlsx.full.min.js"
    ],
    "outputPath": "dist"
  }
}
